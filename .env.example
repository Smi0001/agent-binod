ANTHROPIC_API_KEY=

# Gitea configuration (default platform)
GITEA_TOKEN=
GITEA_BASE=
GITEA_REPO=

# GitHub configuration (use --platform=github)
GITHUB_TOKEN=
GITHUB_REPO=

# Optional: override git base branch for local diff/commit ops (default: upstream/gp-3.0)
BASE_BRANCH=

# Optional: max open PRs to fetch per listing (default: 50, GitHub max: 100)
PR_FETCH_LIMIT=
