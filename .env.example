ANTHROPIC_API_KEY=

# Gitea configuration (default platform)
GITEA_TOKEN=
GITEA_BASE=
GITEA_REPO=

# GitHub configuration (use --platform=github)
GITHUB_TOKEN=
GITHUB_REPO=

# Optional: base branch used when fetching PR diffs via local git (default: upstream/gp-3.0).
# The agent first tries to diff the PR locally using your cloned repo (faster, no API call).
# Set this to the branch your PRs are merged into, e.g. origin/main or upstream/main.
# If unset or if the local diff fails, the agent falls back to fetching the diff via the platform API.
BASE_BRANCH=

# Optional: max open PRs to fetch per listing (default: 50, GitHub max: 100)
PR_FETCH_LIMIT=

# Optional: timeout in milliseconds for local git commands like fetch and diff (default: 30000).
# Increase this for large repos or slow networks.
GIT_TIMEOUT_MS=

# Optional: max characters to read from a PR diff (default: 20000).
# Increase this for large PRs. Claude's context window supports up to ~100000 safely.
# If the diff exceeds this limit, a truncation warning is added so Claude knows it's a partial review.
DIFF_MAX_CHARS=

# Optional: comma-separated list of files/patterns to skip when reading PR diffs.
# Useful for excluding generated or noisy files (lock files, build output, minified assets).
# Supports exact names, prefix/ (directory), and *.ext (extension) patterns.
# Example: DIFF_SKIP_FILES=package-lock.json,yarn.lock,dist/,*.min.js,*.min.css
DIFF_SKIP_FILES=
